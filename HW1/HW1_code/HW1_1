# Newton Method
def newton_method(X, y):
    X_add_w0 = add_w0(X)
    n_samples, n_features = X_add_w0.shape
    
    w = np.zeros(n_features)
    loss_history = []
    
    for epoch in range(epochs):
        y_pred = X_add_w0 @ w
        error = y_pred - y
        grad = (2 / n_samples) * (X_add_w0.T @ error)
        H = (2 / n_samples) * (X_add_w0.T @ X_add_w0)
        w = w - np.linalg.inv(H) @ grad
        loss = mse(y, y_pred)
        loss_history.append(loss)

    print("w_nm =", w)
    return w, loss_history

