# Gradient Descent
def gradient_descent(X, y, lr):
    X_add_w0 = add_w0(X)
    n_samples, n_features = X_add_w0.shape
    
    # 初始化w
    w = np.zeros(n_features)
    
    # 损失值数组
    loss_history = []
    
    for epoch in range(epochs):
        '''
        损失函数mse
        算梯度、参数更新、loss
        '''
        y_pred = X_add_w0 @ w
        error = y_pred - y
        grad = (2 / n_samples) * (X_add_w0.T @ error)
        w = w - lr * grad
        loss = mse(y, y_pred)
        loss_history.append(loss)

    print("w_gd =", w)
    return w, loss_history

