# mse
def mse(y_true, y_pred):
    return np.mean((y_true - y_pred) ** 2)

# 重构X矩阵，最前面加一列1
def add_w0(X):
    '''
    X_add_w0 = 
    ([[1, 1],   
      [1, 2],   
      [1, 3]])
    '''
    ones = np.ones((X.shape[0], 1))
    X_new = np.hstack([ones, X])
    return X_new


#计算预测值
def predict(X,w):
    X_add_w0 = add_w0(X)
    y_pred = X_add_w0 @ w
    '''
     X_add_w0 =    w=[b,k]^T 矩阵乘法->回到一维
    ([[1, 1],   
      [1, 2],   
      [1, 3]])
    '''
    return y_pred

#true/pred
def plot(X,y,y_pred,c_X, c_y,
        title,X_true_label, y_pred_label):
    '''
    true:y,c_X,X_true_label
    pred:y_pred,c_y,y_pred_label
    '''
    plt.scatter(X[:, 0], y,color=c_X, label=X_true_label)
    plt.plot(X[:, 0], y_pred, color=c_y, label=y_pred_label)
    plt.xlabel("x")
    plt.ylabel("y")
    plt.title(title)
    plt.legend()
    plt.show()

